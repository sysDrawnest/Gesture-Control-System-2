# ============================================
# MongoDB Atlas Configuration
# ============================================
MONGODB_URI=mongodb+srv://sethysaiyangyadatta_db_user:0XYoS8cNxDZLPfEA@cluster0.fdj1zn3.mongodb.net/?retryWrites=true&w=majority&appName=Cluster0
USE_MONGODB=True
DATABASE_NAME=gesture_control

# ============================================
# Authentication & Security
# ============================================
# JWT Secret for Authentication (Change this to a random string for production)
JWT_SECRET=gesture-control-system-final-year-project-2026-secret-key

# Flask Secret Key
SECRET_KEY=flask-gesture-control-secret-key-2026

# JWT Expiration (in hours)
JWT_EXPIRATION_HOURS=24

# Bcrypt rounds for password hashing
BCRYPT_LOG_ROUNDS=12

# ============================================
# Server Configuration
# ============================================
FLASK_ENV=production
HOST=0.0.0.0
PORT=5000
DEBUG=False
TESTING=False

# ============================================
# Session Configuration
# ============================================
SESSION_TIMEOUT_HOURS=24
SESSION_TYPE=filesystem
PERMANENT_SESSION_LIFETIME=86400

# ============================================
# Gesture Control Settings
# ============================================
CURSOR_SMOOTHING_FACTOR=0.7
CLICK_HOLD_TIME=0.2
DOUBLE_CLICK_TIME=0.3
PINCH_THRESHOLD=0.04
GESTURE_CONFIDENCE_THRESHOLD=0.7
MAX_CURSOR_SPEED=2000
CURSOR_ACCELERATION=1.2

# ============================================
# WebSocket Configuration
# ============================================
WEBSOCKET_PING_INTERVAL=25
WEBSOCKET_PING_TIMEOUT=60
WEBSOCKET_MAX_MESSAGE_SIZE=1024

# ============================================
# Rate Limiting
# ============================================
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# ============================================
# CORS Configuration
# ============================================
ALLOWED_ORIGINS=http://localhost:5000,http://127.0.0.1:5000,http://localhost:3000,http://192.168.1.*

# ============================================
# Logging Configuration
# ============================================
LOG_LEVEL=INFO
LOG_FILE=gesture_control.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# ============================================
# Email Configuration (Optional - for password reset)
# ============================================
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_USE_TLS=True
MAIL_USE_SSL=False
MAIL_DEFAULT_SENDER=noreply@gesturecontrol.com

# ============================================
# Performance Settings
# ============================================
CACHE_TYPE=simple
CACHE_DEFAULT_TIMEOUT=300
THREADED=True
MAX_CONCURRENT_CONNECTIONS=100

# ============================================
# Monitoring & Analytics
# ============================================
ENABLE_ANALYTICS=True
ENABLE_PERFORMANCE_METRICS=True
METRICS_RETENTION_DAYS=30

# ============================================
# Feature Flags
# ============================================
ENABLE_DEVICE_REGISTRATION=True
ENABLE_GESTURE_LOGGING=True
ENABLE_REMOTE_CONTROL=True
ENABLE_MULTI_DEVICE=False